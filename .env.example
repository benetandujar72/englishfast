# ============================================================
# English First AI Tutor - Variables de Entorno
# ============================================================
# Copia este archivo a .env.local para desarrollo local
# En Vercel, configura estas en Settings > Environment Variables

# --- Base de Datos (Supabase PostgreSQL) ---------------------
# Supabase > Project Settings > Database > Connection string
# Pooled connection (puerto 6543) - para la app:
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true
# Direct connection (puerto 5432) - para migraciones Prisma:
DIRECT_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

# --- Anthropic Claude API ------------------------------------
# https://console.anthropic.com > API Keys
ANTHROPIC_API_KEY=sk-ant-api03-...
# Optional model overrides (defaults are set in code)
CLAUDE_DEFAULT_MODEL=claude-sonnet-4-5-20250929
CLAUDE_CHAT_MODEL=claude-sonnet-4-5-20250929
CLAUDE_DIARY_MODEL=claude-sonnet-4-5-20250929
CLAUDE_EXAM_MODEL=claude-sonnet-4-5-20250929

# --- Google AI Studio / Gemini --------------------------------
# https://aistudio.google.com/app/apikey
GOOGLE_AI_API_KEY=AIza...
# Optional model overrides (defaults are set in code)
GEMINI_DEFAULT_MODEL=gemini-3.1-pro-preview
GEMINI_STT_MODEL=gemini-3.1-pro-preview
# Rate limit and payload controls for speaking analysis
SPEAKING_RATE_LIMIT_PER_MIN=8
SPEAKING_MAX_AUDIO_BYTES=6000000

# --- NextAuth v5 ---------------------------------------------
# Genera con: openssl rand -base64 32
AUTH_SECRET=generate-a-random-secret-here
# Google OAuth: console.cloud.google.com > Credentials
AUTH_GOOGLE_ID=xxxx.apps.googleusercontent.com
AUTH_GOOGLE_SECRET=GOCSPX-...
# Se autoconfigura en Vercel, solo necesario en local:
AUTH_URL=http://localhost:3000

# --- Upstash Redis (Rate Limiting - opcional) ----------------
# https://console.upstash.com
UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=AXxx...

# --- Vercel Cron Secret --------------------------------------
CRON_SECRET=generate-another-random-secret

# --- Opcionales ----------------------------------------------
# NEXT_PUBLIC_APP_URL=https://tu-dominio.vercel.app
